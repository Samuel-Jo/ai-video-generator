# ──────────────────────────────────────────────
# AI 영상 자동화 - 환경 설정 템플릿
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# Windows: copy .env.example .env
# ──────────────────────────────────────────────

# [필수] Google Gemini API 키
# 발급: https://aistudio.google.com → Get API Key (무료)
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# [필수] Pexels API 키
# 발급: https://www.pexels.com/api/ → Your API Key (무료)
PEXELS_API_KEY=여기에_Pexels_API_키_입력

# [선택] Unsplash API 키 (없어도 동작)
# 발급: https://unsplash.com/developers (무료)
UNSPLASH_API_KEY=

# [권장] Pixabay API 키 - 야생동물 영상 품질 대폭 향상
# 발급: https://pixabay.com/api/ → 회원가입 → API Key 복사 (무료, 1분)
PIXABAY_API_KEY=여기에_Pixabay_API_키_입력

# [선택] Cloudflare R2 스토리지 (없으면 로컬에 저장됨)
# 발급: https://dash.cloudflare.com → R2 → Manage API Tokens
CF_ACCOUNT_ID=
R2_ENDPOINT=https://<계정ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aivideo

# TTS 음성 (기본값 그대로 사용 가능)
# 다른 음성: ko-KR-SunHiNeural (여성), ko-KR-InJoonNeural (남성2)
TTS_VOICE=ko-KR-HyunsuNeural
